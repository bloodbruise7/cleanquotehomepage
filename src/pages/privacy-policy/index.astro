---
import Layout from '../../layouts/Layout.astro';

const LAST_UPDATED = 'March 19, 2026';
const LOGO_URL =
  'https://qtrypzzcjebvfcihiynt.supabase.co/storage/v1/object/public/base44-prod/public/6966ac3f075c93d04f0065ad/f52e9713f_file_00000000d788722f8d707c0fc8248d08.png';

const sections = [
  {
    intro: `This Privacy Policy explains how CleanQuote LLC ("CleanQuote," "we," "us," or "our") collects, uses, discloses, and protects personal information when you visit our websites, create an account, start a trial, purchase a subscription, use our software and related services, communicate with us, or interact with messages, quotes, invoices, payment links, and other workflows processed through the CleanQuote platform.

CleanQuote provides software for residential cleaning businesses and related service businesses. In many cases, CleanQuote processes personal information on behalf of our business customers, such as information about their customers, leads, employees, and contractors. When we do that, the business customer controls the information, and we act as a service provider or processor on that customer's behalf.

If you are a customer, lead, employee, or other contact of a business that uses CleanQuote, your information may be processed through our platform on that business's behalf. In that case, questions about how your information is used, corrected, or deleted should generally be directed to that business first. If needed, you may also contact us at info@thecleanquote.com.`,
  },
  {
    title: '1. Scope of This Privacy Policy',
    body: `This Privacy Policy applies to personal information we collect directly from you, automatically through your use of our website or platform, and from third parties involved in providing our services.

It applies to information collected through the CleanQuote application, thecleanquote.com, app.thecleanquote.com, subscription and billing workflows, support interactions, and communications sent or received through the platform.

It does not apply to third-party websites, services, or applications that are not controlled by CleanQuote, even if they are integrated with or linked from our services.`,
  },
  {
    title: '2. Information We Collect',
    body: `We may collect the following categories of personal information:

Account and business information, such as your name, business name, email address, phone number, login credentials, billing contact details, business preferences, and subscription information.

Customer and lead information submitted by our users, such as names, email addresses, phone numbers, service addresses, job details, notes, quote history, invoice information, payment status, and communication history.

Workforce and operations information submitted by our users, such as employee or contractor names, schedules, time-tracking records, breaks, lunches, and related operational notes.

Payment and transaction information, such as subscription status, billing history, invoice records, payment status, and transaction metadata. Payment card numbers and related card details are processed by Stripe and are not stored by CleanQuote except to the extent reflected in processor-provided metadata or billing records.

Communications data, such as emails, SMS messages, message delivery records, opt-out status, customer responses, support requests, and account notices.

Technical and device information, such as IP address, browser type, device type, operating system, referring URLs, pages viewed, timestamps, app events, and log data.

Cookie and similar technology data, including information associated with session cookies, authentication cookies, security cookies, preference cookies, and similar technologies used to operate and improve the service.`,
  },
  {
    title: '3. How We Collect Information',
    body: `We collect personal information directly from you when you create an account, start a trial, subscribe, enter or import data, send quotes or invoices, activate payment or messaging features, contact support, or otherwise use the service.

We collect information automatically through cookies, server logs, and similar technologies when you visit our websites or use our platform.

We receive information from service providers and integrated tools that help us operate the platform, including Stripe, Twilio, SendGrid, Base44, and Amazon Web Services.

We may receive updated contact, billing, delivery, or fraud-prevention information from third parties involved in processing payments, sending communications, securing the service, or hosting the platform.`,
  },
  {
    title: '4. How We Use Personal Information',
    body: `We use personal information for the following purposes:

• To provide, operate, maintain, secure, and improve the CleanQuote platform and related services.
• To create and manage user accounts, authenticate users, administer subscriptions, and provide customer support.
• To generate, store, send, and manage quotes, invoices, payment links, reminders, customer messages, and operational workflows requested by our users.
• To process subscription billing, facilitate customer payment collection through Stripe-enabled workflows, reconcile transactions, detect fraud, and manage chargebacks or disputes.
• To deliver transactional emails, SMS messages, service notices, security alerts, and account-related communications.
• To analyze performance, reliability, usage patterns, product quality, and service effectiveness.
• To enforce our terms, protect our rights, prevent misuse, and comply with legal obligations.
• To develop new features, troubleshoot issues, and create aggregated or de-identified insights that do not reasonably identify an individual.`,
  },
  {
    title: '5. Messaging, Email, and Customer Communications',
    body: `CleanQuote allows business users to send email and SMS communications to their customers and leads from within the platform.

Our business users are responsible for ensuring that they have all legally required notices, permissions, and consents before sending communications through the platform, including any consent required under applicable texting, telemarketing, email, privacy, or consumer-protection laws.

We may process message content, routing information, timestamps, delivery events, opt-out status, and related records as necessary to provide messaging functionality, maintain audit logs, detect abuse, and comply with legal obligations.

If you receive a message from a business using CleanQuote and no longer want to receive those messages, you should follow any opt-out instructions in the message and may also contact the sending business directly.`,
  },
  {
    title: '6. Payments and Financial Information',
    body: `CleanQuote uses Stripe to process subscription payments owed to CleanQuote and, where enabled, customer payments collected by businesses through the CleanQuote platform.

When payments are processed through Stripe, Stripe may collect and process payment card information, billing details, transaction details, and fraud-prevention data under Stripe's own privacy practices.

CleanQuote may receive and store limited payment-related information from Stripe, such as customer identifiers, payment status, payment method type, invoice records, charge status, and transaction metadata, but CleanQuote does not store full payment card numbers.

If you submit payment information through a Stripe-hosted or Stripe-powered workflow, that information is governed in part by Stripe's privacy and security practices.`,
  },
  {
    title: '7. Cookies and Similar Technologies',
    body: `CleanQuote uses cookies and similar technologies to operate, secure, and improve our website and platform.

These technologies may be used to keep you signed in, remember preferences, maintain sessions, prevent fraud, understand how the service is used, and improve functionality.

At this time, CleanQuote does not use Google Analytics, Meta Pixel, or similar advertising or analytics tracking tools for cross-context behavioral advertising.

You can control cookies through your browser settings, but disabling some cookies may affect platform functionality.`,
  },
  {
    title: '8. How We Disclose Personal Information',
    body: `We may disclose personal information to the following categories of recipients:

• Service providers and infrastructure providers that help us host, secure, maintain, deliver, and support the platform, including Amazon Web Services, Base44, Stripe, Twilio, and SendGrid.
• Our professional advisors, such as lawyers, accountants, insurers, auditors, and similar advisors, where necessary for legitimate business purposes.
• Government authorities, regulators, courts, law enforcement, or other parties where required by law, subpoena, court order, legal process, or to protect rights, safety, or property.
• A buyer, investor, lender, successor, or other relevant party in connection with a merger, acquisition, financing, asset sale, restructuring, bankruptcy, or similar transaction.
• The business account holder or authorized users associated with the relevant account, where information is processed within that customer's workspace or operational environment.`,
  },
  {
    title: '9. Sale or Sharing of Personal Information',
    body: `CleanQuote does not sell personal information for money.

CleanQuote does not sell personal information and does not share personal information for cross-context behavioral advertising.

Because CleanQuote does not sell or share personal information for cross-context behavioral advertising, we do not offer a sale or sharing opt-out at this time.`,
  },
  {
    title: '10. Data Retention',
    body: `We retain personal information for as long as reasonably necessary for the purposes described in this Privacy Policy, including to provide the service, maintain business and tax records, resolve disputes, enforce agreements, detect fraud, maintain security, and comply with legal obligations.

Retention periods may vary depending on the type of information, the nature of the relationship, legal requirements, product settings, and operational needs.

When personal information is no longer reasonably necessary, we may delete, de-identify, or aggregate it, subject to applicable legal and operational requirements.`,
  },
  {
    title: '11. Security',
    body: `We use reasonable administrative, technical, and organizational safeguards designed to protect personal information against unauthorized access, destruction, loss, alteration, disclosure, or misuse.

However, no security system is perfect, and we cannot guarantee absolute security of personal information or transmissions over the internet.`,
  },
  {
    title: '12. Your Privacy Rights',
    body: `Depending on where you live, you may have privacy rights regarding personal information we hold about you, subject to applicable exceptions and verification requirements.

These rights may include the right to know what personal information we collect, use, disclose, or retain; the right to request deletion; the right to request correction of inaccurate information; and the right not to be discriminated against for exercising applicable privacy rights.

You may submit privacy-related requests by emailing info@thecleanquote.com.

If we receive a request relating to information that we process on behalf of one of our business customers, we may direct you to that customer or coordinate with that customer as appropriate.`,
  },
  {
    title: '13. Additional Notice for California Residents',
    body: `If you are a California resident, you may have rights under the California Consumer Privacy Act, as amended, including the right to know, delete, correct, and receive information about certain disclosures of personal information, subject to applicable exceptions.

California residents may also have the right to opt out of the sale or sharing of personal information and to limit certain uses of sensitive personal information where those rights apply.

CleanQuote does not sell personal information and does not share personal information for cross-context behavioral advertising.

California residents have the right not to receive discriminatory treatment for exercising their privacy rights.

To exercise applicable California privacy rights, email info@thecleanquote.com.`,
  },
  {
    title: "14. Children's Privacy",
    body: `CleanQuote is not directed to children, and we do not knowingly collect personal information from children under 13.

If we learn that we have collected personal information from a child under 13 without appropriate authorization, we will take reasonable steps to delete that information.`,
  },
  {
    title: '15. International Use',
    body: `CleanQuote is operated in the United States and is intended primarily for users located in the United States.

If you access the service from outside the United States, you understand that your information may be transferred to, stored in, and processed in the United States and other jurisdictions where our service providers operate.`,
  },
  {
    title: '16. Changes to This Privacy Policy',
    body: `We may update this Privacy Policy from time to time. If we make material changes, we may post the updated version in the platform, update the Last Updated date above, and provide additional notice where appropriate.

Your continued use of the service after an updated Privacy Policy becomes effective constitutes acceptance of the revised policy, to the extent permitted by law.`,
  },
  {
    title: '17. Contact Us',
    body: `If you have questions about this Privacy Policy or want to submit a privacy request, contact us at:

info@thecleanquote.com`,
  },
];
---

<Layout
  title="Privacy Policy — CleanQuote"
  description="How CleanQuote LLC collects, uses, discloses, and protects personal information across our website, platform, and related services."
  canonical="https://thecleanquote.com/privacy-policy/"
  ogTitle="Privacy Policy — CleanQuote"
  ogDescription="How CleanQuote LLC collects, uses, discloses, and protects personal information across our website, platform, and related services."
  ogUrl="https://thecleanquote.com/privacy-policy/"
>
  <div class="min-h-screen bg-white">
    <div class="max-w-3xl mx-auto px-6 py-12">
      <div class="flex justify-center mb-10">
        <a href="/">
          <img src={LOGO_URL} alt="CleanQuote" class="h-16 w-auto" />
        </a>
      </div>

      <h1 class="text-3xl font-bold text-gray-900 text-center mb-2">Privacy Policy</h1>
      <p class="text-sm text-gray-500 text-center mb-10">Last Updated: {LAST_UPDATED}</p>

      <div class="space-y-8">
        {sections.map((section) => (
          <div>
            {section.intro && (
              <p class="text-gray-700 leading-relaxed whitespace-pre-line">{section.intro}</p>
            )}
            {section.title && (
              <h2 class="text-xl font-semibold text-gray-900 mb-3">{section.title}</h2>
            )}
            {section.body && (
              <p class="text-gray-700 leading-relaxed whitespace-pre-line">{section.body}</p>
            )}
          </div>
        ))}
      </div>

      <div class="mt-16 pt-8 border-t border-gray-200 text-center">
        <p class="text-sm text-gray-400">© 2026 CleanQuote LLC. All rights reserved.</p>
      </div>
    </div>
  </div>
</Layout>
