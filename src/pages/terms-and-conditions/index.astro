---

<Layout
  title="Terms of Service — CleanQuote"
  description="The binding Terms of Service between CleanQuote LLC and the person or entity accessing or using the CleanQuote Services."
  canonical="https://thecleanquote.com/terms-and-conditions/"
  ogTitle="Terms of Service — CleanQuote"
  ogDescription="The binding Terms of Service between CleanQuote LLC and the person or entity accessing or using the CleanQuote Services."
  ogUrl="https://thecleanquote.com/terms-and-conditions/"
>
  <div class="min-h-screen bg-white">
    <div class="max-w-3xl mx-auto px-6 py-12">
      <div class="flex justify-center mb-10">
        <a href="/">
          <img src={LOGO_URL} alt="CleanQuote" class="h-16 w-auto" />
        </a>
      </div>

      <h1 class="text-3xl font-bold text-gray-900 text-center mb-2">Terms of Service</h1>
      <p class="text-sm text-gray-500 text-center mb-10">Last Updated: {LAST_UPDATED}</p>

      <div class="space-y-8">
        {sections.map((section) => (
          <div>
            {section.intro && (
              <p class="text-gray-700 leading-relaxed whitespace-pre-line">{section.intro}</p>
            )}
            {section.title && (
              <h2 class="text-xl font-semibold text-gray-900 mb-3">{section.title}</h2>
            )}
            {section.body && (
              <p class="text-gray-700 leading-relaxed whitespace-pre-line">{section.body}</p>
            )}
          </div>
        ))}
      </div>

      <div class="mt-16 pt-8 border-t border-gray-200 text-center">
        <p class="text-sm text-gray-400">© 2026 CleanQuote LLC. All rights reserved.</p>
      </div>
    </div>
  </div>
</Layout>
